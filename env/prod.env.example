COMPOSE_PROJECT_NAME=aimoda-prod
NGINX_PORT=38080
FRONTEND_URL=https://ai-moda.ai
SERVER_URL=https://ai-moda.ai
API_PORT=3000
JWT_SECRET=SET_IN_GITHUB_SECRET
ACCESS_TOKEN_EXPIRES_IN=2h
REFRESH_TOKEN_EXPIRES_IN=7d

REPORT_MCP_INTERNAL_TOKEN=aimoda-report-mcp-internal-token
REPORT_MCP_SERVICE_USER_ID=1

QDRANT_URL=http://YOUR_QDRANT_HOST:16333
QDRANT_API_KEY=SET_IN_GITHUB_SECRET
QDRANT_COLLECTION=fashion_items

LLM_PROVIDER=openai
LLM_MODEL=qwen3.5-flash
LLM_API_KEY=SET_IN_GITHUB_SECRET
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=32768
LLM_THINKING_ENABLED=false

FALLBACK_LLM_ENABLED=true
FALLBACK_LLM_PROVIDER=anthropic
FALLBACK_LLM_MODEL=MiniMax-M2.7-highspeed
FALLBACK_LLM_API_KEY=SET_IN_GITHUB_SECRET
FALLBACK_LLM_BASE_URL=https://api.minimaxi.com/anthropic
FALLBACK_LLM_THINKING_ENABLED=false

OPENAI_API_KEY=SET_IN_GITHUB_SECRET
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VLM_MODEL=qwen3.5-flash
VLM_TEMPERATURE=0.1
VLM_MAX_TOKENS=1200
VLM_TIMEOUT_SECONDS=45

EMBEDDING_URL=http://YOUR_EMBEDDING_HOST:18730
EMBEDDING_MODEL=Marqo/marqo-fashionSigLIP
STYLE_KNOWLEDGE_EMBEDDING_URL=http://YOUR_EMBEDDING_HOST:18730
STYLE_KNOWLEDGE_EMBEDDING_MODEL=infgrad/stella-mrl-large-zh-v3.5-1792d
STYLE_KNOWLEDGE_VECTOR_DIM=1792

OSS_ACCESS_KEY_ID=SET_IN_GITHUB_SECRET
OSS_ACCESS_KEY_SECRET=SET_IN_GITHUB_SECRET
OSS_BUCKET_NAME=your-bucket
OSS_ENDPOINT=oss-cn-shenzhen.aliyuncs.com
OSS_REGION=oss-cn-shenzhen
OSS_PUBLIC_BASE=https://your-bucket.oss-cn-shenzhen.aliyuncs.com
OSS_USE_HTTPS=true
OSS_CORS_ALLOWED_ORIGINS=*
OSS_CORS_ALLOWED_METHODS=GET,HEAD,PUT,POST
OSS_CORS_ALLOWED_HEADERS=*
OSS_CORS_EXPOSE_HEADERS=ETag,x-oss-request-id
OSS_CORS_MAX_AGE_SECONDS=86400

SMS_PROVIDER=aliyun
FAVORITE_UPLOAD_JOB_STALE_SECONDS=1800
ALIYUN_SMS_ACCESS_KEY_ID=SET_IN_GITHUB_SECRET
ALIYUN_SMS_ACCESS_KEY_SECRET=SET_IN_GITHUB_SECRET
ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com
ALIYUN_SMS_SIGN_NAME=深圳市像素澎湃科技
ALIYUN_SMS_TEMPLATE_CODE=SMS_498250051

COVER_ASSET_BASE_URL=

# Runtime capacity profile (prod: baseline for approx. 200 concurrent users)
API_WORKERS=6
API_BACKLOG=2048
API_KEEP_ALIVE_TIMEOUT=30
API_CPUS=6
API_CPU_RESERVATION=2
API_MEM_LIMIT=6g
API_MEM_RESERVATION=2g

POSTGRES_CPUS=2
POSTGRES_CPU_RESERVATION=1
POSTGRES_MEM_LIMIT=2g
POSTGRES_MEM_RESERVATION=1g

REDIS_CPUS=1
REDIS_CPU_RESERVATION=0.25
REDIS_MEM_LIMIT=1g
REDIS_MEM_RESERVATION=256m

FRONTEND_CPUS=1
FRONTEND_CPU_RESERVATION=0.25
FRONTEND_MEM_LIMIT=768m
FRONTEND_MEM_RESERVATION=256m

STYLE_MCP_CPUS=1
STYLE_MCP_CPU_RESERVATION=0.25
STYLE_MCP_MEM_LIMIT=768m
STYLE_MCP_MEM_RESERVATION=256m

GALLERY_MCP_CPUS=1
GALLERY_MCP_CPU_RESERVATION=0.25
GALLERY_MCP_MEM_LIMIT=768m
GALLERY_MCP_MEM_RESERVATION=256m

REPORT_MCP_CPUS=0.5
REPORT_MCP_CPU_RESERVATION=0.25
REPORT_MCP_MEM_LIMIT=256m
REPORT_MCP_MEM_RESERVATION=128m

NGINX_CPUS=1
NGINX_CPU_RESERVATION=0.25
NGINX_MEM_LIMIT=768m
NGINX_MEM_RESERVATION=256m
