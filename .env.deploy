JWT_SECRET=SET_IN_DEPLOY_ENV
FRONTEND_URL=https://your-domain.example
API_PORT=3000
REPORTS_VOLUME_PATH=/reports
ACCESS_TOKEN_EXPIRES_IN=2h
REFRESH_TOKEN_EXPIRES_IN=7d

# Agent / Chat
QDRANT_API_KEY=SET_IN_DEPLOY_ENV
LLM_API_KEY=SET_IN_DEPLOY_ENV

# Aliyun OSS
OSS_ACCESS_KEY_ID=SET_IN_DEPLOY_ENV
OSS_ACCESS_KEY_SECRET=SET_IN_DEPLOY_ENV
